# AWS Bedrock Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file to version control!
#
# Optional: You can omit .env entirely if you use go-aws-sso or another
# AWS profile flow that writes credentials to ~/.aws/credentials.

# Required: Your AWS Access Key ID
AWS_ACCESS_KEY_ID=your_access_key_here

# Required: Your AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# Required for temporary credentials (e.g., from AWS Academy or STS)
# Leave empty or remove this line if using permanent credentials
AWS_SESSION_TOKEN=your_session_token_here

# Optional: AWS Region (defaults to us-east-1 if not specified)
AWS_REGION=us-east-1

# ============================================================================
# OPTIONAL: Application Settings Overrides
# ============================================================================
# These settings can override values in config.yaml.
# For most use cases, edit config.yaml instead of using environment variables.
# Environment variables are useful for CI/CD or deployment-specific overrides.

# Optional: Maximum number of transcripts to process in parallel
# Overrides config.yaml parallel_processing.max_workers
# Default: 3 (from config.yaml)
# MAX_PARALLEL_WORKERS=3

# Optional: Bedrock Model ID
# Overrides config.yaml model.model_id
# Default: global.anthropic.claude-sonnet-4-6 (from config.yaml)
# MODEL_ID=global.anthropic.claude-sonnet-4-6

# Optional: AI Temperature (0.0-1.0)
# Overrides config.yaml model.temperature
# Default: 0.3 (from config.yaml)
# TEMPERATURE=0.3
